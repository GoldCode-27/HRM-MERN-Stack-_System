# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hrm

# JWT secret used for signing tokens
e.g. a long random string
JWT_SECRET=your_jwt_secret_here

# Email configuration for onboarding and reports
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=HRM System <your-email@example.com>

# Frontend app URL used for password reset links
FRONTEND_URL=http://localhost:5173

# Backend port
PORT=5001
